{
  "manifest_version": 2,
  "name": "MegaCloudFix",
  "version": "1.0",
  "description": "Redirects megacloud.blog requests to megacloud.tv",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "*://*.megacloud.blog/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  }
}
